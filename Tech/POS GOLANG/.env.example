# Environment
APP_PORT=8080
APP_ENV=development
APP_NAME=POS-Golang

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pos_golang
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Payment Gateway (Midtrans)
PAYMENT_SERVER_KEY=your-midtrans-server-key
PAYMENT_CLIENT_KEY=your-midtrans-client-key
PAYMENT_ENV=sandbox

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m
